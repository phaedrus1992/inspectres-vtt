{
  "settings": {
    "typescript": {
      "extensions": [".ts", ".tsx"]
    },
    "jsdoc": true
  },
  "rules": {
    "typescript/no-unused-vars": "warn",
    "typescript/no-explicit-any": "error",
    "typescript/explicit-function-return-types": "off",
    "no-console": ["warn", { "allow": ["warn", "error"] }],
    "no-debugger": "error",
    "no-var": "error",
    "prefer-const": "warn",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "no-empty": "warn",
    "no-unreachable": "error"
  }
}
