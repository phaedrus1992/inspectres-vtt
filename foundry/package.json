{
  "name": "inspectres-vtt",
  "version": "0.1.0",
  "description": "InSpectres paranormal investigation RPG system for Foundry VTT",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "prod": "vite build --config vite.config.prod.ts",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@vitest/coverage-v8": "^3.1.2",
    "fvtt-types": "github:League-of-Foundry-Developers/foundry-vtt-types#main",
    "jsdom": "^26.1.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2",
    "vitest": "^3.1.2"
  }
}
